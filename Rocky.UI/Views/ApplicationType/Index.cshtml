@model IEnumerable<ApplicationType>
@{
    ViewData["Title"] = "Index";
}

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">Application types</h2>
        </div>

        <div class="col-6 text-end">
            <a asp-controller="ApplicationType" asp-action="Create" class="btn btn-primary">
                <i class="fa-solid fa-plus"></i> Create New Application type
            </a>

        </div>
    </div>

    <br /> <br />

    @if (Model.Count() > 0)
    {
        <table class="table table-bordered table-striped" style="width:100%">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Name</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                @foreach (var applicationType in Model)
                {
                    <tr>
                        <td width="50%">@applicationType.Id</td>
                        <td width="50%">@applicationType.Name</td>
                        <td>
                            <div class="w-75 btn-group mx-2" role="group">
                                <a asp-controller="ApplicationType" asp-action="Edit"
                                   asp-route-id="@applicationType.Id" class="btn btn-primary ms-2">
                                    <i class="fa-solid fa-edit"></i>
                                </a>

                                <a asp-controller="ApplicationType" asp-action="Delete"
                                   asp-route-id="@applicationType.Id" class="btn btn-danger ms-2">
                                    <i class="fa-solid fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No application types</p>
    }
</div>



