@model IEnumerable<Product>
@{
    ViewData["Title"] = "Index";
}

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">Products</h2>
        </div>

        <div class="col-6 text-end">
            <a asp-action="Save" class="btn btn-primary">
                <i class="fa-solid fa-plus"></i> Create New Product
            </a>

        </div>
    </div>

    <br /> <br />

    @if (Model.Count() > 0)
    {
        <table class="table table-bordered table-striped" style="width:100%">
            <thead>
                <tr>
                    <th>Product Name</th>
                    <th>Price</th>
                    <th>Category Name</th>
                    <th>Appication Type</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td width="30%">@product.Name</td>
                        <td width="10%">@product.Price</td>
                        <td width="20%">@product.Category.Name</td>
                        <td width="20%">@product.ApplicationType.Name</td>
                        <td class="text-center">
                            <div class="w-75 btn-group mx-2" role="group">
                                <a asp-action="Save" asp-route-id="@product.Id" class="btn btn-primary ms-2">
                                    <i class="fa-solid fa-edit"></i>
                                </a>

                                <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-danger ms-2">
                                    <i class="fa-solid fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No products</p>
    }
</div>



