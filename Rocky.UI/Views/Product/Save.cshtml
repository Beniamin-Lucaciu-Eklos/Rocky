@model Product
@{
    ViewData["Title"] = "Save";
    var isEditAction = Model is { Id: > 0 };
    var title = isEditAction ? "Edit" : "Create";
}

<form method="post" asp-action="Save" enctype="multipart/form-data">
    @if (isEditAction)
    {
        <input asp-for="Id" hidden />
    }

    <div class="border p-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-group row">
            <h2 class="text-info pl-3">
                @title
            </h2>
        </div>

        <div class="mb-3 row">
            <label asp-for="Name" class="col-sm-2 col-form-label">Name</label>
            <div class="col-sm-10">
                <input asp-for="Name" class="form-control">
                <span asp-validation-for="Name" class="text-danger" />
            </div>
        </div>

        <div class="mb-3 row">
            <label asp-for="Price" class="col-sm-2 col-form-label">Price</label>
            <div class="col-sm-10">
                <input asp-for="Price" class="form-control">
                <span asp-validation-for="Price" class="text-danger" />
            </div>
        </div>

        <div class="mb-3 row">
            <label asp-for="Description" class="col-sm-2 col-form-label">Description</label>
            <div class="col-sm-10">
                <input asp-for="Description" class="form-control">
                <span asp-validation-for="Description" class="text-danger" />
            </div>
        </div>

        <div class="mb-3 row">
            <label class="col-sm-2 col-form-label">Image</label>
            <div class="col-sm-10">
                <input type="file" name="files" id="uploadBox" multiple class="form-control">
            </div>
        </div>

        <div class="mb-3 row">
            <label asp-for="Category" class="col-sm-2 col-form-label">Category</label>
            <div class="col-sm-10">
                <select asp-for="CategoryId" asp-items="@ViewBag.CategoryDropdown" class="form-control">
                    <option selected>--Select category--</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger" />
            </div>
        </div>

        <div class="mb-3 row">
            <div class="col-sm-6">
                @if (isEditAction)
                {
                    <input type="submit" class="btn btn-info w-100" value="@title" />
                }
                else
                {
                    <input type="submit" class="btn btn-info w-100" onclick="return validateInput();" value="@title" />
                }
            </div>

            <div class="col-sm-6">
                <a asp-action="Index" class="btn btn-success w-100">
                    <i class="fa-solid fa-circle-arrow-left"></i> Back
                </a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}