@model Product

<form method="post" asp-action="DeletePost">
    @Html.AntiForgeryToken()

    <div class="border p-3">
        <input asp-for="@Model.Id" hidden />

        <div class="form-group row">
            <h2 class="text-info pl-3">
                @Model.Name
            </h2>
        </div>

        <div class="row">
            <div class="col-8">

                <div class="mb-3 row">
                    <label asp-for="@Model.Name" class="col-sm-2 col-form-label">Name</label>
                    <div class="col-sm-10">
                        <input asp-for="@Model.Name" class="form-control" disabled>
                    </div>
                </div>

                <div class="mb-3 row">
                    <label asp-for="@Model.Price" class="col-sm-2 col-form-label">Price</label>
                    <div class="col-sm-10">
                        <input asp-for="@Model.Price" class="form-control" disabled>
                    </div>
                </div>

                <div class="mb-3 row">
                    <label asp-for="@Model.Description" class="col-sm-2 col-form-label">Description</label>
                    <div class="col-sm-10">
                        <textarea asp-for="@Model.Description" class="form-control" disabled></textarea>
                    </div>
                </div>

                <div class="mb-3 row">
                    <label asp-for="@Model.Image" class="col-sm-2 col-form-label">Image</label>
                    <div class="col-sm-10">
                        <input asp-for="@Model.Image" class="form-control" disabled>
                    </div>
                </div>

                <div class="mb-3 row">
                    <label asp-for="@Model.Category" class="col-sm-2 col-form-label">Category</label>
                    <div class="col-sm-10">
                        <input asp-for="@Model.Category.Name" class="form-control" disabled>
                    </div>
                </div>

                <div class="mb-3 row">
                    <label asp-for="@Model.ApplicationType" class="col-sm-2 col-form-label">ApplicationType</label>
                    <div class="col-sm-10">
                        <input asp-for="@Model.ApplicationType.Name" class="form-control" disabled>
                    </div>
                </div>

                <div class="mb-3 row">
                    <div class="col-sm-6">
                        <input type="submit" class="btn btn-danger w-100" value="Delete" />
                    </div>

                    <div class="col-sm-6">
                        <a asp-action="Index" class="btn btn-success w-100">
                            <i class="fa-solid fa-circle-arrow-left"></i> Back
                        </a>
                    </div>
                </div>

            </div>

            <div class="col-3 offset-1">
                <img src="@WWWRootConstants.ProductImagesPath@Model.Image"
                     alt="@Model.Name"
                     title="@Model.Name"
                     width="100%" disabled />
            </div>

        </div>
    </div>
</form>